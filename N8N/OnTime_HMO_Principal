        "jsCode": "function normalize(s) {\n  return (s || \"\")\n    .toLowerCase()\n    .normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\") // quita acentos\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\nconst months = {\n  enero: 0, febrero: 1, marzo: 2, abril: 3, mayo: 4, junio: 5,\n  julio: 6, agosto: 7, septiembre: 8, setiembre: 8, octubre: 9, noviembre: 10, diciembre: 11,\n};\n\nconst weekdayRe = /\\b(lunes|martes|miercoles|miércoles|jueves|viernes|sabado|sábado|domingo)\\b\\s+(\\d{1,2})\\s+de\\s+([a-záéíóú]+)/gi;\n\nfunction bestYearFor(monthIndex, day, tz = \"America/Hermosillo\") {\n  // año dinámico: usa el año actual en esa TZ; si la fecha ya pasó, asume el siguiente año\n  const now = new Date();\n  const nowParts = new Intl.DateTimeFormat(\"en-CA\", { timeZone: tz, year: \"numeric\", month: \"2-digit\", day: \"2-digit\" })\n    .formatToParts(now)\n    .reduce((a, p) => (a[p.type] = p.value, a), {});\n  const y = Number(nowParts.year);\n  const m = Number(nowParts.month) - 1;\n  const d = Number(nowParts.day);\n\n  if (monthIndex < m || (monthIndex === m && day < d)) return y + 1;\n  return y;\n}\n\nfunction realWeekdayES(date, tz = \"America/Hermosillo\") {\n  // weekday real en español\n  return normalize(new Intl.DateTimeFormat(\"es-MX\", { timeZone: tz, weekday: \"long\" }).format(date));\n}\n\nfunction fixWeekdaysInText(text, tz = \"America/Hermosillo\", mode = \"remove\") {\n  // mode: \"remove\" (quita lunes/martes/...) o \"correct\" (corrige al real)\n  return text.replace(weekdayRe, (full, wd, dayStr, monthStr) => {\n    const day = Number(dayStr);\n    const monthKey = normalize(monthStr);\n    const monthIndex = months[monthKey];\n    if (monthIndex === undefined || day < 1 || day > 31) return full;\n\n    const year = bestYearFor(monthIndex, day, tz);\n    // fecha a medio día para evitar brincos raros por timezone/DST\n    const date = new Date(Date.UTC(year, monthIndex, day, 12, 0, 0));\n\n    const wdReal = realWeekdayES(date, tz);\n    const wdGiven = normalize(wd);\n\n    if (wdReal !== wdGiven) {\n      if (mode === \"correct\") return `${wdReal} ${day} de ${monthStr}`; // conserva el mes como venía\n      return `${day} de ${monthStr}`; // remove\n    }\n    return full;\n  });\n}\n\n\nlet data = $input.item.json.output;\nfor (let itemName in data) {\n  let msg = data[itemName].replace(/\\b(?:de|del)\\s+2026\\b/g, '').replace(/\\s{2,}/g, ' ').trim();\n  msg = fixWeekdaysInText(msg, \"America/Hermosillo\", \"correct\"); // o \"correct\"\n  let words = msg.split(\" \")\n  let delay = words.length * 0.9;\n  if (delay < 1.5) {\n    delay = 1\n  }\n  if (delay > 3) {\n    delay = 1\n  }\n  $input.item.json.output[itemName] = {\n    msg,\n    delay\n  }\n}\n\nreturn $input.item;"
