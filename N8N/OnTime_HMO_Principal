      "parameters": {
        "jsCode": "const calId = $('calendar_time_search').first().json.calendarID\nconst intervalMinutes = $('calendar_time_search').first().json.minutesInterval\nconst timeZone = \"America/Phoenix\"\n\nconst busyTimes = $input.item.json.calendars[calId].busy;\n\n\nfunction mergeIntervals(intervals) {\n  if (!intervals.length) return [];\n  const sorted = intervals\n    .map(i => ({ start: new Date(i.start), end: new Date(i.end) }))\n    .sort((a, b) => a.start - b.start);\n  const merged = [sorted[0]];\n  for (const curr of sorted.slice(1)) {\n    const last = merged[merged.length - 1];\n    if (curr.start <= last.end) {\n      last.end = new Date(Math.max(last.end, curr.end));\n    } else {\n      merged.push(curr);\n    }\n  }\n  return merged;\n}\n\n\nfunction formatISOWithOffset(date) {\n  // 1. Crear formateador en la zona de Phoenix\n  const dtf = new Intl.DateTimeFormat('en-CA', {\n    timeZone,\n    hour12: false,\n    year: 'numeric',\n    month: '2-digit',\n    day: '2-digit',\n    hour: '2-digit',\n    minute: '2-digit',\n    second: '2-digit',\n  });\n  // 2. Extraer partes individuales\n  const parts = dtf.formatToParts(date).reduce((acc, p) => {\n    if (p.type !== 'literal') acc[p.type] = p.value;\n    return acc;\n  }, {});\n\n  // 3. Offset fijo de Phoenix (UTC−7)\n  const offset = '-07:00'; \n\n  // 4. Reconstruir ISO-8601 con offset\n  return `${parts.year}-${parts.month}-${parts.day}T${parts.hour}:${parts.minute}:${parts.second}${offset}`;\n}\n\nfunction getFreeSlotsForDay(dayStart, dayEnd, busyIntervals, interval, timeZone) {\n  console.log('dayStart', dayStart);\n  console.log('dayEnd', dayEnd);\n  const startWork = new Date(dayStart);\n  const endWork = new Date(dayEnd);\n  console.log('===>', startWork, endWork);\n  const mergedBusy = mergeIntervals(busyIntervals);\n  const slots = [];\n  let cursor = startWork;\n\n  for (const block of [...mergedBusy, { start: endWork, end: endWork }]) {\n    while (new Date(cursor.getTime() + interval * 60000) <= block.start) {\n      const slotEnd = new Date(cursor.getTime() + interval * 60000);\n      slots.push({\n        start: formatISOWithOffset(cursor),\n        end: formatISOWithOffset(slotEnd)\n      });\n      cursor = slotEnd;\n    }\n    cursor = new Date(Math.max(cursor, block.end));\n  }\n  return slots;\n}\n\nconst allBusy = busyTimes.map(b => ({ start: b.start, end: b.end }));\n\nconst freeSlots = [];\n\nconst dayStart = new Date($input.first().json.timeMin);\nconst dayEnd = new Date($input.first().json.timeMax);\n\n// Filtrar ocupados de ese día\nconst busyOfDay = allBusy.filter(b =>\n  new Date(b.start).toDateString() === dayStart.toDateString()\n);\nfreeSlots.push(\n  ...getFreeSlotsForDay(dayStart, dayEnd, busyOfDay, intervalMinutes, timeZone)\n);\n\n\nreturn [{ json: { freeSlots, busyTimes } }];\n"
